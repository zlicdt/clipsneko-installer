pkgname=clipsneko-installer
pkgver=0.1.0
pkgrel=1
pkgdesc="TUI installer for ClipsNeko Linux"
arch=('x86_64')
url="https://github.com/zlicdt/clipsneko-installer"
license=('GPL-3.0-only')
depends=('gcc-libs' 'glibc')
makedepends=('cargo' 'gettext' 'git')
backup=('etc/clipsneko-installer/packages.list')
source=("$pkgname::git+$url.git#tag=v$pkgver")
sha256sums=('SKIP')

prepare() {
  cd "$pkgname"
  cargo fetch --locked
}

build() {
  cd "$pkgname"
  cargo build --frozen --release
}

check() {
  cd "$pkgname"
  cargo test --frozen --all-targets
}

package() {
  cd "$pkgname"

  install -Dm755 "target/release/$pkgname" "$pkgdir/usr/bin/$pkgname"
  install -Dm644 config/packages.list \
    "$pkgdir/etc/clipsneko-installer/packages.list"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

  local lang
  for lang in en zh_CN zh_TW ja de ko ru; do
    install -d "$pkgdir/usr/share/locale/$lang/LC_MESSAGES"
    msgfmt --check --check-header \
      -o "$pkgdir/usr/share/locale/$lang/LC_MESSAGES/$pkgname.mo" \
      "po/$lang/LC_MESSAGES/$pkgname.po"
  done
}

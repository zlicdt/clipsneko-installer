# might be produced by running msgfmt manually inside po/.
*.mo
*.gmo

# --- Editor / IDE ---
*.swp
*.swo
*~
.vscode/
.idea/
*.iml

# --- OS metadata ---
.DS_Store
Thumbs.db
desktop.ini

# --- Local environment / secrets ---
.env
.env.local
.env.*.local
